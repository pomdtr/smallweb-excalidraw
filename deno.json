{
    "name": "@smallweb/excalidraw",
    "version": "0.3.7",
    "exports": {
        ".": "./mod.ts"
    },
    "tasks": {
        "install-deps": "cd frontend && npm install",
        "build-frontend": "cd frontend && npm run build",
        "embed": "deno run -A embedder.ts build",
        "build": "deno task build-frontend && deno task embed"
    },
    "publish": {
        "include": [
            "mod.ts",
            "dist",
            "file_server.ts"
        ]
    }
}
